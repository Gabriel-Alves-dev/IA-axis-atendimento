# Copie para .env.production na VM e preencha. NUNCA commite o .env.production.
# Os valores de Supabase/OpenAI são os mesmos do seu app/.env.local de dev.

# --- Supabase (gerenciado, supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- IA ---
OPENAI_API_KEY=

# --- WAHA (o compose sobrepõe WAHA_BASE_URL para http://waha:3000 — não defina aqui) ---
WAHA_API_KEY=
WAHA_WEBHOOK_SECRET=
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=

# --- URL pública do painel (mesma do Caddyfile), usada nos webhooks (Mercado Pago) ---
WEBHOOK_BASE_URL=https://app.seudominio.com.br

# --- Só enquanto estiver usando credenciais de TESTE do Mercado Pago ---
# MP_TEST_PAYER_EMAIL=TESTUSER...@testuser.com
