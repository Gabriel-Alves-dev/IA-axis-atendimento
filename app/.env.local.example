# Copie para .env.local e preencha com valores reais.

# Supabase — Settings > API no painel do seu projeto
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# OpenAI — usada como IA padrão da plataforma
OPENAI_API_KEY=

# WAHA (docker-compose.yml na raiz do projeto)
WAHA_BASE_URL=http://localhost:3001
WAHA_API_KEY=

# URL onde este app é alcançado pelo WAHA para entregar os webhooks de mensagem.
# Em dev local com Docker Desktop, não precisa de túnel público:
WEBHOOK_BASE_URL=http://host.docker.internal:3000
# Segredo compartilhado com o WAHA para validar a assinatura HMAC do webhook (string aleatória)
WAHA_WEBHOOK_SECRET=
